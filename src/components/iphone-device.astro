---
interface Props {
  src: string;
  alt: string;
  className?: string;
}

const { src, alt, className = "" } = Astro.props as Props;
---

<div class={`iphone-hardware ${className}`}>
  <div class="iphone-hardware__shadow"></div>
  <div class="iphone-hardware__body">
    <span class="iphone-hardware__button iphone-hardware__button--mute"></span>
    <span class="iphone-hardware__button iphone-hardware__button--up"></span>
    <span class="iphone-hardware__button iphone-hardware__button--down"></span>
    <span class="iphone-hardware__button iphone-hardware__button--power"></span>
    <div class="iphone-hardware__frame">
      <div class="iphone-hardware__island"></div>
      <div class="iphone-hardware__screen">
        <img src={src} alt={alt} loading="eager" />
        <span class="iphone-hardware__glow"></span>
      </div>
    </div>
  </div>
</div>

<style>
  .iphone-hardware {
    position: relative;
    display: block;
    width: min(100%, var(--device-width, 15rem));
    margin: 0 auto;
    transform: var(--device-transform, none);
  }

  .iphone-hardware__shadow {
    position: absolute;
    inset: 10% 7% -4%;
    border-radius: 3.2rem;
    background: radial-gradient(circle at center, rgba(16, 24, 40, 0.38), transparent 68%);
    filter: blur(18px);
  }

  .iphone-hardware__body {
    position: relative;
    z-index: 1;
    aspect-ratio: 0.486;
    padding: 0.36rem;
    border-radius: 3.45rem;
    background:
      linear-gradient(150deg, rgba(255, 255, 255, 0.92) 0%, rgba(205, 208, 214, 0.92) 20%, rgba(118, 123, 132, 0.98) 52%, rgba(39, 42, 49, 1) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.55),
      inset 0 -1px 0 rgba(0, 0, 0, 0.28),
      0 26px 70px rgba(15, 23, 42, 0.25);
  }

  .iphone-hardware__frame {
    position: relative;
    height: 100%;
    overflow: hidden;
    border-radius: 3.05rem;
    padding: 0.33rem;
    background: linear-gradient(180deg, rgba(16, 16, 19, 1), rgba(0, 0, 0, 1));
  }

  .iphone-hardware__screen {
    position: relative;
    height: 100%;
    overflow: hidden;
    border-radius: 2.72rem;
    background: #000;
  }

  .iphone-hardware__screen img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .iphone-hardware__glow {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(138deg, rgba(255, 255, 255, 0.16), transparent 20%, transparent 62%, rgba(255, 255, 255, 0.07) 74%, transparent 82%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent 16%);
    pointer-events: none;
  }

  .iphone-hardware__island {
    position: absolute;
    left: 50%;
    top: 0.65rem;
    z-index: 2;
    width: 35%;
    height: 1.7rem;
    transform: translateX(-50%);
    border-radius: 999px;
    background:
      radial-gradient(circle at 28% 50%, rgba(46, 46, 52, 0.9) 0, rgba(20, 20, 24, 1) 36%, rgba(0, 0, 0, 1) 68%),
      #000;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .iphone-hardware__button {
    position: absolute;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(146, 151, 161, 1), rgba(82, 87, 97, 1));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
  }

  .iphone-hardware__button--mute {
    left: -0.13rem;
    top: 5.05rem;
    width: 0.18rem;
    height: 1rem;
  }

  .iphone-hardware__button--up {
    left: -0.16rem;
    top: 7rem;
    width: 0.22rem;
    height: 2rem;
  }

  .iphone-hardware__button--down {
    left: -0.16rem;
    top: 9.5rem;
    width: 0.22rem;
    height: 2rem;
  }

  .iphone-hardware__button--power {
    right: -0.16rem;
    top: 8rem;
    width: 0.22rem;
    height: 3rem;
  }
</style>
