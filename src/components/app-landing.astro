---

<div class="min-h-screen bg-[#f5f5f7] text-[#1d1d1f]">
  <header class="sticky top-0 z-50 border-b border-black/6 bg-[rgba(245,245,247,0.72)] backdrop-blur-2xl">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4 lg:px-8">
      <a href="#" class="flex items-center gap-3 text-sm tracking-tight text-black">
        <img
          src="/brand/app-logo.png"
          alt={uiText.logoAlt}
          class="size-10 rounded-[0.9rem] border border-black/8 bg-white object-cover shadow-[0_8px_24px_rgba(15,23,42,0.08)]"
          loading="eager"
          decoding="async"
        />
        <span class="hidden sm:block">
          <span class="block text-[0.98rem] font-semibold">Games for Watch</span>
          <span class="block text-xs text-black/48">{uiText.headerTagline}</span>
        </span>
      </a>

      <nav class="hidden items-center gap-7 text-sm text-black/56 lg:flex">
        {copy.nav.map((item) => (
          <a href={item.url} class="transition hover:text-black">
            {item.title}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-2.5">
        <details class="language-switcher">
          <summary class="language-switcher__summary">
            <span>Language</span>
            <span class="language-switcher__current">{copy.languages.find((item) => item.active)?.title ?? "EN"}</span>
            <Icon name="mdi:chevron-down" class="size-4 text-black/52" />
          </summary>
          <div class="language-switcher__menu">
            {copy.languages.map((item) => (
              <a
                href={item.url}
                class:list={[
                  "language-switcher__item",
                  item.active && "language-switcher__item--active",
                ]}
              >
                <span>{item.title}</span>
                {item.active && <Icon name="mdi:check" class="size-4 shrink-0" />}
              </a>
            ))}
          </div>
        </details>
        <a
          href={copy.appStoreUrl}
          target="_blank"
          rel="noreferrer"
          class="inline-flex rounded-full border border-black/10 bg-white px-4 py-2.5 text-sm font-semibold text-black transition hover:border-black/20 hover:bg-white/80"
        >
          {uiText.downloadShort}
        </a>
      </div>
    </div>
  </header>

  <main>
    <section class="hero-stage overflow-hidden">
      <div class="mx-auto max-w-7xl px-6 pb-1 pt-8 lg:px-8 lg:pb-3 lg:pt-10">
        <p class="whitespace-nowrap font-semibold tracking-[-0.02em] text-black/96" style="font-size: clamp(1.8rem, 3.1vw, 4rem);">
          {heroEyebrow}
        </p>
        <div class="mt-4 grid items-start gap-16 lg:grid-cols-[5fr_4fr]">
          <div class="hero-copy min-w-0 max-w-none">
            <h1 class:list={[
              "max-w-full font-semibold tracking-[-0.07em] text-black leading-[0.92] sm:leading-[0.94]",
              copy.lang === "zh-CN"
                ? "max-w-none text-balance"
                : "max-w-none text-balance",
            ]}
            style={copy.lang === "zh-CN" ? "font-size: clamp(2.35rem, 4.6vw, 6.4rem);" : "font-size: clamp(3rem, 4.3vw, 5.4rem);"}>
              {heroTitle}
            </h1>
            <p class="mt-6 max-w-[24rem] text-[1rem] leading-[1.7] text-black/60 lg:text-[1.04rem]">
              {copy.heroLead}
            </p>
            <div class="mt-9 flex flex-wrap items-center gap-4">
              <a
                href={copy.appStoreUrl}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-2.5 rounded-full bg-black px-7 py-4 text-sm font-semibold text-white shadow-[0_18px_50px_rgba(15,23,42,0.22)] transition hover:bg-black/86"
              >
                <Icon name="mdi:apple" class="size-5 shrink-0" />
                {copy.ctaPrimary}
              </a>
              <a
                href="#gallery"
                class="inline-flex rounded-full border border-black/10 bg-white/82 px-7 py-4 text-sm font-semibold text-black transition hover:border-black/20 hover:bg-white"
              >
                {copy.ctaSecondary}
              </a>
            </div>
          </div>

          <div class="hero-visual min-w-0 lg:pr-8" aria-hidden="true">
            <div class="hero-visual__scene">
              <div class="hero-visual__halo hero-visual__halo--a"></div>
              <div class="hero-visual__halo hero-visual__halo--b"></div>
              <div class="hero-visual__ring"></div>
              <div class="hero-visual__watch hero-visual__watch--left">
                <WatchDevice
                  src={heroWatchShots[0]}
                  alt={uiText.heroAltOne}
                  showBands={false}
                  className="[--device-width:100%] [--device-transform:rotate(-15deg)]"
                />
              </div>
              <div class="hero-visual__watch hero-visual__watch--center">
                <WatchDevice
                  src={heroWatchShots[1]}
                  alt={uiText.heroAltTwo}
                  showBands={false}
                  className="[--device-width:100%] [--device-transform:translateY(-0.6rem)]"
                />
              </div>
              <div class="hero-visual__watch hero-visual__watch--right">
                <WatchDevice
                  src={heroWatchShots[2]}
                  alt={uiText.heroAltThree}
                  showBands={false}
                  className="[--device-width:100%] [--device-transform:rotate(15deg)]"
                />
              </div>
            </div>
          </div>
        </div>
        <div id="proof" class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3 lg:mt-12">
          {copy.proofItems.map((item, index) => (
            <article class="editorial-card">
              <div class="proof-card__title-row">
                <span class="proof-card__icon">
                  <Icon name={proofIcons[index] ?? "mdi:gamepad-round-outline"} class="size-8" />
                </span>
                <h3 class="text-2xl font-semibold tracking-tight text-black">{item.title}</h3>
              </div>
              <p class="mt-3 text-sm leading-6 text-black/56">{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="gallery" class="bg-white">
      <div class="mx-auto max-w-7xl px-4 py-24 lg:px-6 lg:py-28">
        <div class="max-w-3xl">
